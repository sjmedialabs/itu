# Copy to .env and fill in values (never commit .env).

# --- Catalog (countries / operators / plans): Supabase Postgres via PostgREST ---
# Apply SQL from supabase/catalog_schema.sql (+ optional catalog_seed.sql) in the SQL Editor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# When plans/operators tables are empty: 1 = serve demo SKUs (any NODE_ENV), 0 = never. Default = demo only in development.
# CATALOG_DEMO_FALLBACK=

# --- Ding Connect — recharge settlement only (app/api/recharge); catalog APIs no longer use Ding ---
DING_API_BASE_URL=https://api.dingconnect.com
DING_API_KEY=
DING_CLIENT_ID=
DING_CLIENT_SECRET=
